# Supabase Configuration
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# OpenAI Configuration
VITE_OPENAI_API_KEY=your-openai-api-key

# App Configuration
VITE_APP_NAME=Reddit Pulse
VITE_APP_VERSION=1.0.0
VITE_APP_ENV=development

# Reddit API Configuration (if using authenticated endpoints)
VITE_REDDIT_CLIENT_ID=your-reddit-client-id
VITE_REDDIT_CLIENT_SECRET=your-reddit-client-secret
VITE_REDDIT_USER_AGENT=RedditPulse/1.0.0

# Analytics (optional)
VITE_GOOGLE_ANALYTICS_ID=your-ga-id
VITE_MIXPANEL_TOKEN=your-mixpanel-token
